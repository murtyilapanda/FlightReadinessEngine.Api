<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UserSecretsId>flightreadinessengine.api-local</UserSecretsId>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
		<PackageReference Include="Google.Cloud.AIPlatform.V1" Version="3.72.0" />
		<PackageReference Include="Google.Cloud.BigQuery.V2" Version="3.12.0" />
		<PackageReference Include="Google.Cloud.Datastore.V1" Version="5.2.0" />
	</ItemGroup>

	<ItemGroup>
		<None Include="zinc-hour-*.json" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>

</Project>